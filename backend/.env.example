# TiDB Cloud is MySQL-compatible. Public TiDB Cloud connections commonly use port 4000 and TLS.
# URL-encode special characters in the password.
DATABASE_URL=mysql+pymysql://user:password@gateway-region.aws.tidbcloud.com:4000/database?ssl_verify_cert=true&ssl_verify_identity=true
APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1
SHELBY_API_URL=
SHELBY_API_KEY=your_aptos_api_key_here
SHELBY_INDEXER_URL=https://api.testnet.aptoslabs.com/nocode/v1/public/alias/shelby/testnet/v1/graphql
SHELBY_RPC_URL=https://api.testnet.shelby.xyz/shelby
CORS_ORIGINS=http://localhost:5173
