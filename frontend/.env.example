# ─────────────────────────────────────────────────────────────────────────────
# Shelby Proof-of-Data — Frontend Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Aptos Labs API Key (REQUIRED to fix the 401 error)
# Get a FREE key at: https://developers.aptoslabs.com/
VITE_APTOS_API_KEY=your_aptos_api_key_here

# Aptos account private key for signing Shelby uploads (REQUIRED)
# Steps to get one:
#   1. Install Aptos CLI: https://aptos.dev/tools/aptos-cli
#   2. Run: aptos init --network testnet
#   3. Run: aptos account fund-with-faucet --account default
#   4. Run: aptos config show-profiles
#   5. Copy the private_key value here (starts with 0x)
VITE_APTOS_PRIVATE_KEY=0x_your_testnet_private_key_here
