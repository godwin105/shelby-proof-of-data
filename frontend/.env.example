# ─────────────────────────────────────────────────────────────────────────────
# Shelby Proof-of-Data — Frontend Environment Variables
# Copy this file to .env and fill in your Aptos Labs API key.
# Users connect their OWN Petra wallet — no private key needed here.
# ─────────────────────────────────────────────────────────────────────────────

# Aptos Labs API Key (fixes 401 error on Shelby testnet)
# Get a FREE key at: https://developers.aptoslabs.com/
VITE_APTOS_API_KEY=your_aptos_api_key_here

# Backend API base URL.
# Local dev can leave this blank because Vite proxies /api to FastAPI.
# Production example: https://your-backend.onrender.com/api/v1
VITE_API_BASE_URL=
